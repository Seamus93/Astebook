{
  "name": "astebook-pipeline",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "start:prod": "prisma migrate deploy && node backend/server.js",
    "start:4000": "set PORT=4000&& node backend/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "lint": "node scripts/check-js.js",
    "test": "node --test backend/tests/*.test.js",
    "build": "npm run lint && vite build",
    "frontend:dev": "vite --host 0.0.0.0",
    "ci": "npm run lint && npm test && npm audit --audit-level=high",
    "ngrok": "ngrok http 4000",
    "all": "concurrently \"npm run start:4000\" \"npm run ngrok\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "docxtemplater": "^3.69.0",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "imapflow": "^1.4.7",
    "mailparser": "^3.9.14",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.48.0",
    "pdf-parse": "^2.4.4",
    "pizzip": "^3.2.0",
    "prisma": "^6.19.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "vite": "^8.1.3"
  }
}
