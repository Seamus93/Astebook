{
  "name": "astebook-pipeline",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "start:4000": "set PORT=4000&& node server.js",
    "lint": "node scripts/check-js.js",
    "test": "node --test",
    "build": "npm run lint",
    "ci": "npm run lint && npm test && npm audit --audit-level=high",
    "ngrok": "ngrok http 4000",
    "all": "concurrently \"npm run start:4000\" \"npm run ngrok\""
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.7.0",
    "pdf-parse": "^2.4.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
